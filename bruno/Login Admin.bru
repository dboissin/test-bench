meta {
  name: Login Admin
  type: http
  seq: 2
}

post {
  url: {{kc_url}}/protocol/openid-connect/token
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  client_id: {{client_id}}
  grant_type: password
  username: adminuser
  password: adminpass
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("admin_token", res.body.access_token);
  }
}

assert {
  res.status: eq 200
}
