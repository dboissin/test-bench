<config xmlns="urn:org:jgroups"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:org:jgroups http://www.jgroups.org/schema/jgroups-5.2.xsd">

    <TCP bind_addr="127.0.0.1"
         bind_port="7800"
         port_range="10"
         recv_buf_size="5M"
         send_buf_size="5M"
         sock_conn_timeout="300"
         thread_pool.min_threads="0"
         thread_pool.max_threads="200"
         thread_pool.keep_alive_time="30000"/>

    <TCPPING initial_hosts="127.0.0.1[7800],127.0.0.1[7801]"
             port_range="0"/>

    <MERGE3 min_interval="10000" max_interval="30000"/>
    <FD_SOCK2/>
    <FD_ALL3 timeout="40000" interval="5000"/>
    <VERIFY_SUSPECT2 timeout="1500"/>

    <pbcast.NAKACK2 use_mcast_xmit="false"/>
    <UNICAST3/>

    <pbcast.STABLE desired_avg_gossip="50000"
                   max_bytes="4M"/>

    <pbcast.GMS print_local_addr="true"
                join_timeout="2000"/>

    <UFC max_credits="4M" min_threshold="0.4"/>
    <MFC max_credits="4M" min_threshold="0.4"/>
    <FRAG2 frag_size="60K"/>
</config>
